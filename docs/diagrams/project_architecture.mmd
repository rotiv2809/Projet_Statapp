flowchart LR
    %% Entry points
    U[User]
    ST[Streamlit UI\nstreamlit_app.py]
    CLI[CLI\napp/main.py]

    %% Main runtime orchestrator
    P[Pipeline Orchestrator\napp/pipeline/data_pipeline.py]

    %% Agents
    subgraph AG[Multi-Agent Layer]
      G[GuardrailsAgent]
      S[SQLAgent]
      E[ErrorAgent]
      A[AnalysisAgent]
      V[VizAgent]
    end

    %% Safety + routing
    subgraph SAFE[Safety and Routing]
      GK[gatekeeper.py + schemas.py]
      R[router_agent.py]
      SV[sql_validator.py]
    end

    %% Data + formatting
    subgraph DATA[Data and Formatting]
      X[execute_sql.py]
      DB[sqlite.py + SQLite DB]
      F1[format_response.py]
      F2[viz_plotly.py fallback]
    end

    %% LLM layer
    LLM[llm/factory.py\nOpenAI / Google / Ollama]

    %% Optional orchestration
    LG[Optional: langgraph_flow.py\nbuild_text2sql_graph()]

    U --> ST --> P
    U --> CLI --> P

    P --> G
    G --> GK
    G --> R

    P --> S --> LLM
    P --> E --> LLM
    P --> A --> LLM
    P --> V --> LLM

    P --> SV
    P --> X
    X --> SV
    X --> DB

    P --> F1
    P --> F2

    LG -. uses same agents and helpers .-> G
    LG -.-> S
    LG -.-> E
    LG -.-> A
    LG -.-> V
    LG -.-> X
    LG -.-> SV
    LG -.-> DB
    LG -.-> F1
    LG -.-> F2
