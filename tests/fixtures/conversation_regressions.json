          "status": "OUT OF SCOPE",
          "parsed_intent": "unsafe_sql_or_injection",
          "notes": "Refused"
        },
        "sql": "SELECT 1",
        "execute_result": {
          "ok": true,
          "columns": ["dummy"],
          "rows": [[1]]
        }
      }
    ],
    "expect": {
      "route": "OUT_OF_SCOPE",
      "answer_text_contains": [
        "destructive or raw SQL"
      ]
    }
  }
